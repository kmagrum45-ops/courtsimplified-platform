# =========================================================

/.next/
/out/
/build/

# =========================================================
# TYPESCRIPT
# =========================================================

*.tsbuildinfo
next-env.d.ts

# =========================================================
# ENVIRONMENT / SECRETS
# =========================================================

.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# =========================================================
# API KEYS / CREDENTIALS
# =========================================================

*credentials*.json
*secret*.json
*service-account*.json
*private-key*.json

# =========================================================
# SUPABASE / DATABASE EXPORTS
# =========================================================

supabase-export/
database-backups/
*.sql.bak

# =========================================================
# GENERATED FILES / REPORTS
# =========================================================

form-compatibility-report.json
project-file-map.txt

# =========================================================
# DOWNLOADS / GENERATED PDFS
# =========================================================

downloads/generated/
downloads/temp/
downloads/uploads/

# =========================================================
# USER FILES / CASE FILES

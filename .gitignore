user-uploads/
case-exports/
generated-documents/

# =========================================================
# LOGS / DEBUG
# =========================================================

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =========================================================
# SYSTEM FILES
# =========================================================

.DS_Store
Thumbs.db
*.pem

# =========================================================
# VERCEL
# =========================================================

.vercel

# =========================================================
# IDE
# =========================================================

.vscode/*
!.vscode/extensions.json

# =========================================================

/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =========================================================
# TESTING / COVERAGE
# =========================================================

/coverage

# =========================================================
